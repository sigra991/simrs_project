generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id         String       @id @default(uuid())
  username   String       @unique
  password   String
  nama       String
  role       Role
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  inventory  Inventory[]  @relation("ApotekerInventory")
  rekamMedis RekamMedis[] @relation("DokterRekamMedis")

  @@map("users")
}

model Pasien {
  id            String        @id @default(uuid())
  no_rm         String        @unique
  nama          String
  nik           String
  tgl_lahir     DateTime
  alamat        String
  jenis_kelamin String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  pendaftaran   Pendaftaran[]

  @@map("pasien")
}

model Pendaftaran {
  id                  String             @id @default(uuid())
  pasienId            String
  tanggal             DateTime           @default(now())
  keluhan_awal        String
  status              StatusAntrean      @default(MENUNGGU)
  kategori_pembayaran KategoriPembayaran @default(UMUM)
  no_bpjs             String?
  instansi_bpjs       String?
  biaya               Decimal?           @db.Decimal(12, 2)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  pasien              Pasien             @relation(fields: [pasienId], references: [id], onDelete: Cascade)
  rekamMedis          RekamMedis?        @relation("PendaftaranRekamMedis")

  @@map("pendaftaran")
}

model RekamMedis {
  id            String      @id @default(uuid())
  pendaftaranId String      @unique
  dokterId      String
  diagnosa      String
  tindakan      String
  tanggal       DateTime    @default(now())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  dokter        User        @relation("DokterRekamMedis", fields: [dokterId], references: [id])
  pendaftaran   Pendaftaran @relation("PendaftaranRekamMedis", fields: [pendaftaranId], references: [id], onDelete: Cascade)
  resep         Resep[]

  @@map("rekam_medis")
}

model Inventory {
  id         String   @id @default(uuid())
  kode_obat  String   @unique
  nama_obat  String
  stok       Int      @default(0)
  harga      Decimal  @db.Decimal(12, 2)
  apotekerId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  apoteker   User     @relation("ApotekerInventory", fields: [apotekerId], references: [id])
  resep      Resep[]

  @@map("inventory")
}

model Resep {
  id           String     @id @default(uuid())
  rekamMedisId String
  inventoryId  String
  jumlah       Int
  dosis        String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  inventory    Inventory  @relation(fields: [inventoryId], references: [id])
  rekamMedis   RekamMedis @relation(fields: [rekamMedisId], references: [id], onDelete: Cascade)

  @@map("resep")
}

enum Role {
  ADMIN
  RESEPSIONIS
  DOKTER
  APOTEKER
}

enum StatusAntrean {
  MENUNGGU
  DIPERIKSA
  SELESAI
}

enum KategoriPembayaran {
  UMUM
  BPJS
}
